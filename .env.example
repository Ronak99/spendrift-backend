# Server
PORT=8080
NODE_ENV=development

# Auth — comma-separated client tokens
SPENDRIFT_CLIENT_TOKENS=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Models — change without iOS update
VOICE_MODEL=gpt-audio-mini
STATEMENT_MODEL=gpt-4o
RECEIPT_MODEL=gpt-4o

# PostHog analytics ingestion proxy upstream (us or eu cloud)
POSTHOG_HOST=https://us.i.posthog.com

# Sentry diagnostics (optional — omit to disable server-side reporting)
SENTRY_DSN=
# iOS envelope tunnel upstream DSN (must match SPENDRIFT_SENTRY_DSN in the iOS app)
SENTRY_TUNNEL_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=spendrift-backend@1.0.0

# Timeouts (ms)
UPSTREAM_TIMEOUT_MS=120000

# Limits
MAX_PDF_BYTES=1
MAX_AUDIO_BYTES=1
MAX_IMAGE_BYTES=8388608
